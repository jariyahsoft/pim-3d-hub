{
  "openapi": "3.1.0",
  "info": {
    "title": "3D Print Marketplace Thailand API",
    "version": "1.0.0",
    "description": "Public REST contract for the marketplace foundation.",
    "license": {
      "name": "Proprietary",
      "url": "https://pim-3d-hub.test/license"
    }
  },
  "servers": [
    {
      "url": "https://api.pim-3d-hub.test/api/v1",
      "description": "Production API"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    },
    {
      "appCheckHeader": []
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "operationId": "getHealth",
        "tags": ["system"],
        "summary": "Health check",
        "security": [],
        "parameters": [
          {
            "$ref": "#/components/parameters/RequestIdHeader"
          },
          {
            "$ref": "#/components/parameters/AppCheckHeader"
          }
        ],
        "responses": {
          "200": {
            "description": "Service is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthEnvelope"
                }
              }
            }
          },
          "500": {
            "description": "Unexpected internal failure",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorEnvelope"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorEnvelope"
                }
              }
            }
          }
        }
      }
    },
    "/readiness": {
      "get": {
        "operationId": "getReadiness",
        "tags": ["system"],
        "summary": "Readiness check",
        "security": [],
        "parameters": [
          {
            "$ref": "#/components/parameters/RequestIdHeader"
          },
          {
            "$ref": "#/components/parameters/AppCheckHeader"
          }
        ],
        "responses": {
          "200": {
            "description": "Service is ready",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReadinessEnvelope"
                }
              }
            }
          },
          "503": {
            "description": "Dependency unavailable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorEnvelope"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorEnvelope"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "Firebase ID token"
      },
      "appCheckHeader": {
        "type": "apiKey",
        "in": "header",
        "name": "X-App-Check"
      }
    },
    "parameters": {
      "RequestIdHeader": {
        "name": "X-Request-Id",
        "in": "header",
        "required": false,
        "schema": {
          "$ref": "#/components/schemas/RequestId"
        }
      },
      "PaginationLimitQuery": {
        "name": "limit",
        "in": "query",
        "required": false,
        "schema": {
          "type": "integer",
          "minimum": 1
        }
      },
      "PaginationCursorQuery": {
        "name": "cursor",
        "in": "query",
        "required": false,
        "schema": {
          "$ref": "#/components/schemas/OpaqueCursor"
        }
      },
      "AppCheckHeader": {
        "name": "X-App-Check",
        "in": "header",
        "required": false,
        "schema": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "schemas": {
      "RequestId": {
        "type": "string",
        "minLength": 1,
        "description": "Opaque request identifier."
      },
      "OpaqueCursor": {
        "type": "string",
        "minLength": 1,
        "description": "Opaque pagination cursor."
      },
      "ApiMeta": {
        "type": "object",
        "additionalProperties": false,
        "required": ["requestId"],
        "properties": {
          "requestId": {
            "$ref": "#/components/schemas/RequestId"
          },
          "nextCursor": {
            "oneOf": [
              {
                "$ref": "#/components/schemas/OpaqueCursor"
              },
              {
                "type": "null"
              }
            ]
          }
        }
      },
      "ApiPageMeta": {
        "type": "object",
        "additionalProperties": false,
        "required": ["requestId", "limit"],
        "properties": {
          "requestId": {
            "$ref": "#/components/schemas/RequestId"
          },
          "nextCursor": {
            "oneOf": [
              {
                "$ref": "#/components/schemas/OpaqueCursor"
              },
              {
                "type": "null"
              }
            ]
          },
          "limit": {
            "type": "integer",
            "minimum": 1
          },
          "total": {
            "type": "integer",
            "minimum": 0
          }
        }
      },
      "ApiError": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "message", "fields", "details", "requestId"],
        "properties": {
          "code": {
            "type": "string",
            "minLength": 1
          },
          "message": {
            "type": "string",
            "minLength": 1
          },
          "fields": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "details": {
            "type": "object",
            "additionalProperties": true
          },
          "requestId": {
            "$ref": "#/components/schemas/RequestId"
          }
        }
      },
      "ApiErrorEnvelope": {
        "type": "object",
        "additionalProperties": false,
        "required": ["error"],
        "properties": {
          "error": {
            "$ref": "#/components/schemas/ApiError"
          }
        }
      },
      "HealthData": {
        "type": "object",
        "additionalProperties": false,
        "required": ["service", "status", "timestamp"],
        "properties": {
          "service": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": ["ok"]
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ReadinessDependency": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "status"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": ["ready", "degraded", "unavailable", "unknown"]
          },
          "message": {
            "type": "string"
          }
        }
      },
      "ReadinessData": {
        "type": "object",
        "additionalProperties": false,
        "required": ["service", "status", "dependencies"],
        "properties": {
          "service": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": ["ready", "degraded", "unready"]
          },
          "dependencies": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ReadinessDependency"
            }
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "HealthEnvelope": {
        "type": "object",
        "additionalProperties": false,
        "required": ["data", "meta"],
        "properties": {
          "data": {
            "$ref": "#/components/schemas/HealthData"
          },
          "meta": {
            "$ref": "#/components/schemas/ApiMeta"
          }
        }
      },
      "ReadinessEnvelope": {
        "type": "object",
        "additionalProperties": false,
        "required": ["data", "meta"],
        "properties": {
          "data": {
            "$ref": "#/components/schemas/ReadinessData"
          },
          "meta": {
            "$ref": "#/components/schemas/ApiMeta"
          }
        }
      }
    }
  }
}
