  "version": "0.0.0",
  "type": "module",
  "dependencies": {
    "openapi-fetch": "^0.17.0",
    "zod": "^4.4.3"
  },
  "scripts": {
    "openapi:check": "node ../../tools/check-openapi-breaking.mjs",
