# Copy this file per environment. Keep local, development, staging and production values separate.

APP_ENV=local
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:3001

FIREBASE_PROJECT_ID=demo-pim-3d-hub-local
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
FIREBASE_STORAGE_EMULATOR_HOST=127.0.0.1:9199
FIREBASE_AUTHORIZED_DOMAINS=localhost,127.0.0.1
FIREBASE_AUTH_REDIRECT_URLS=http://localhost:3000/auth/callback
FIREBASE_PROJECT_LOCAL=demo-pim-3d-hub-local
FIREBASE_PROJECT_DEVELOPMENT=pim-3d-hub-development
FIREBASE_PROJECT_STAGING=pim-3d-hub-staging
FIREBASE_PROJECT_PRODUCTION=pim-3d-hub-production
FIREBASE_CLIENT_EMAIL=service-account@example.invalid
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nREPLACE_WITH_A_REAL_SECRET_OUTSIDE_GIT\n-----END PRIVATE KEY-----

STORAGE_BUCKET=your-storage-bucket
APP_CHECK_MODE=disabled-local
PAYMENT_PROVIDER=sandbox
PAYMENT_WEBHOOK_SECRET=replace-me
EMAIL_PROVIDER=placeholder
PUSH_NOTIFICATION_PROVIDER=placeholder
LINE_NOTIFICATION_CHANNEL_TOKEN=replace-me-if-enabled
SEARCH_PROVIDER=placeholder
FILE_SCAN_PROVIDER=placeholder
OTEL_EXPORTER_ENDPOINT=
LOG_LEVEL=info
